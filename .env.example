# ============================================
# CONFIGURACIÓN OBLIGATORIA
# ============================================

# URI de conexión a MongoDB (requerido)
# Para desarrollo: mongodb://localhost:27017/stateMachine
# Para Atlas: mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/stateMachine

# Frontend URL permitida por CORS (requerido)
# Debe coincidir exactamente con el origen del frontend
FRONTEND_URL=http://localhost:5173

# ============================================
# CONFIGURACIÓN OPCIONAL CON DEFAULTS
# ============================================

# Puerto en el que escucha el servidor
# Default: 5000
PORT=5000

# Entorno de ejecución: development, production, test
# Default: development
NODE_ENV=development

# Nombre de la base de datos MongoDB
# Default: stateMachine
MONGODB_DB_NAME=stateMachine

# Umbral de monto (USD) para crear tickets de soporte en pagos fallidos
# Default: 1000
PAYMENT_REVIEW_THRESHOLD=1000

# Nivel de log: debug, info, warn, error
# Default: info
LOG_LEVEL=info
